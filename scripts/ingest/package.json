{
	"name": "@dariah-eric/ingest",
	"private": true,
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"imports": {
		"#/*": "./*"
	},
	"exports": {
		".": "./dist/index.mjs"
	},
	"scripts": {
		"data:ingest:search": "tsx ./scripts/ingest-search-index.ts",
		"data:ingest:search:entities": "tsx ./scripts/ingest-search-index-entities.ts",
		"data:ingest:search:resources": "tsx ./scripts/ingest-search-index-resources.ts",
		"data:ingest:sshoc": "tsx ./scripts/ingest-sshoc-services.ts",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@dariah-eric/client-campus": "workspace:^",
		"@dariah-eric/client-episciences": "workspace:^",
		"@dariah-eric/client-hal": "workspace:^",
		"@dariah-eric/client-openaire": "workspace:^",
		"@dariah-eric/client-sshoc": "workspace:^",
		"@dariah-eric/client-zenodo": "workspace:^",
		"@dariah-eric/client-zotero": "workspace:^",
		"@dariah-eric/configs": "workspace:^",
		"@dariah-eric/database": "workspace:^",
		"@dariah-eric/env": "workspace:^",
		"@dariah-eric/request": "workspace:^",
		"@dariah-eric/search": "workspace:^",
		"@dariah-eric/search-resources": "workspace:^",
		"@dariah-eric/search-website": "workspace:^",
		"@dariah-eric/sshoc-services": "workspace:^",
		"@dariah-eric/storage": "workspace:^",
		"@types/node": "catalog:",
		"better-result": "catalog:",
		"eslint": "catalog:",
		"remark-parse": "catalog:",
		"remark-stringify": "catalog:",
		"strip-markdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"unified": "catalog:",
		"valibot": "catalog:"
	}
}
