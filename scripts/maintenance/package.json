{
	"name": "@dariah-eric/maintenance",
	"private": true,
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"scripts": {
		"data:clean:empty-content-blocks": "tsx ./scripts/clean-empty-content-blocks.ts",
		"data:clean:richtext": "tsx ./scripts/clean-richtext.ts",
		"data:clean:richtext-links": "tsx ./scripts/clean-richtext-links.ts",
		"data:clean:unused-assets": "tsx ./scripts/clean-unused-assets.ts",
		"data:clean:unused-social-media": "tsx ./scripts/clean-unused-social-media.ts",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "oxlint --report-unused-disable-directives --type-aware --type-check",
		"lint:fix": "oxlint --fix --report-unused-disable-directives --type-aware --type-check",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@dariah-eric/configs": "workspace:^",
		"@dariah-eric/database": "workspace:^",
		"@dariah-eric/env": "workspace:^",
		"@dariah-eric/storage": "workspace:^",
		"@types/node": "catalog:",
		"drizzle-orm": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"valibot": "catalog:"
	},
	"engines": {
		"node": "24.x"
	}
}
