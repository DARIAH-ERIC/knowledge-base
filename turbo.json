{
	"$schema": "./node_modules/turbo/schema.json",
	"globalDependencies": [".env.keys"],
	"globalEnv": [
		"API_ALLOWED_ORIGINS",
		"API_BASE_URL",
		"API_LOG_LEVEL",
		"API_PORT",
		"API_SENTRY_AUTH_TOKEN",
		"API_SENTRY_DSN",
		"API_SENTRY_ORG",
		"API_SENTRY_PII",
		"API_SENTRY_PROJECT",
		"APP_SENTRY_AUTH_TOKEN",
		"AUTH_ENCRYPTION_KEY",
		"AUTH_SIGN_UP",
		"BUILD_MODE",
		"DATABASE_HOST",
		"DATABASE_NAME",
		"DATABASE_PASSWORD",
		"DATABASE_PORT",
		"DATABASE_SSL_CONNECTION",
		"DATABASE_USER",
		"EMAIL_ADDRESS",
		"EMAIL_SMTP_PASSWORD",
		"EMAIL_SMTP_PORT",
		"EMAIL_SMTP_SERVER",
		"EMAIL_SMTP_USERNAME",
		"EMAIL_SSL_CONNECTION",
		"IMGPROXY_BASE_URL",
		"IMGPROXY_KEY",
		"IMGPROXY_PORT",
		"IMGPROXY_SALT",
		"MAILCHIMP_API_BASE_URL",
		"MAILCHIMP_API_KEY",
		"MAILCHIMP_LIST_ID",
		"MAILPIT_API_BASE_URL",
		"NEXT_RUNTIME",
		"NODE_ENV",
		"S3_ACCESS_KEY",
		"S3_BUCKET_NAME",
		"S3_HOST",
		"S3_PORT",
		"S3_PROTOCOL",
		"S3_SECRET_KEY",
		"TYPESENSE_ADMIN_API_KEY",
		"WEBSITE_SENTRY_AUTH_TOKEN"
	],
	"globalPassThroughEnv": ["CI", "ENV_VALIDATION", "PORT"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", "**/.env.local", "**/.env.*.local"],
			"outputs": [
				".next/**",
				"!.next/cache/**",
				"dist/**",
				"out/**",
				"storybook-static/**",
				"*.tsbuildinfo"
			]
		},
		"dev": {
			"cache": false,
			"dependsOn": ["^build"],
			"persistent": true
		},
		"dev:watch": {
			"cache": false,
			"dependsOn": ["^build"],
			"persistent": true
		},
		"//#format:check": {
			"outputs": [".prettiercache"]
		},
		"//#format:fix": {
			"outputs": [".prettiercache"]
		},
		"format:check": {
			"outputs": [".prettiercache"]
		},
		"format:fix": {
			"outputs": [".prettiercache"]
		},
		"lint:check": {
			"dependsOn": ["^build"],
			"outputs": [".stylelintcache"]
		},
		"lint:fix": {
			"dependsOn": ["^build"],
			"outputs": [".stylelintcache"]
		},
		"start": {
			"cache": false,
			"dependsOn": ["^build"],
			"persistent": true
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$"],
			"outputs": ["coverage/**"]
		},
		"test:e2e": {
			"dependsOn": ["^build"],
			"env": ["PLAYWRIGHT_TEST_APP_BASE_URL"],
			"inputs": ["$TURBO_DEFAULT$", "**/.env.local", "**/.env.*.local"]
		},
		"test:e2e:update-snapshots": {
			"dependsOn": ["^build"],
			"env": ["PLAYWRIGHT_TEST_APP_BASE_URL"],
			"inputs": ["$TURBO_DEFAULT$", "**/.env.local", "**/.env.*.local"]
		},
		"types:check": {
			"dependsOn": ["^build"],
			"outputs": ["*.tsbuildinfo"]
		}
	}
}
