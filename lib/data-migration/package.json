{
	"name": "@dariah-eric/data-migration",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"sideEffects": false,
	"scripts": {
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"get-unr-schema": "drizzle-kit introspect --config=./config/unr-db.config.ts",
		"migrate": "tsx ./scripts/migrate.ts",
		"migrate-unr-data": "tsx ./scripts/migrate-unr-data.ts",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@dariah-eric/database": "workspace:^",
		"@dariah-eric/env": "workspace:^",
		"@dariah-eric/storage": "workspace:^",
		"@sindresorhus/slugify": "catalog:",
		"@tiptap/core": "catalog:",
		"@tiptap/extension-image": "catalog:",
		"@tiptap/html": "catalog:",
		"@tiptap/starter-kit": "catalog:",
		"drizzle-orm": "catalog:",
		"hast-util-to-text": "catalog:",
		"rehype-parse": "catalog:",
		"unified": "catalog:",
		"valibot": "catalog:"
	},
	"devDependencies": {
		"@dariah-eric/configs": "workspace:^",
		"@types/node": "catalog:",
		"drizzle-kit": "catalog:",
		"eslint": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"wp-types": "catalog:"
	}
}
