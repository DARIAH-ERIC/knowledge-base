{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"ignorePatterns": [
		"**/messages/*.json",
		"pnpm-workspace.yaml",
		"apps/*/content/",
		"apps/*/e2e/snapshots/",
		"apps/*/public/",
		"packages/database/db/migrations/",
		"turbo/generators/**/*.hbs"
	],
	"jsdoc": true,
	"printWidth": 100,
	"sortImports": {
		"groups": [
			["side_effect"],
			["side_effect_style"],
			["style"],
			["builtin"],
			["external"],
			["internal", "subpath"],
			["unknown"]
		]
	},
	"sortPackageJson": {
		"sortScripts": true
	},
	"useTabs": true
}
