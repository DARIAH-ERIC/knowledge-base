{
	"$schema": "./node_modules/lefthook/schema.json",
	"pre-commit": {
		"commands": {
			"eslint": {
				"run": "eslint --fix {staged_files}",
				"stage_fixed": true
			},
			"stylelint": {
				"glob": "*.css",
				"run": "stylelint --cache --fix {staged_files}",
				"stage_fixed": true
			},
			"oxfmt": {
				"run": "oxfmt --no-error-on-unmatched-pattern --write {staged_files}",
				"stage_fixed": true
			}
		}
	}
}
