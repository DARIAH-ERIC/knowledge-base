{
	"$schema": "./node_modules/lefthook/schema.json",
	"pre-commit": {
		"commands": {
			"oxlint": {
				"run": "pnpm exec eslint --fix --flag unstable_native_nodejs_ts_config {staged_files}",
				"stage_fixed": true
			},
			"stylelint": {
				"glob": "*.css",
				"run": "pnpm exec stylelint --fix {staged_files}",
				"stage_fixed": true
			},
			"oxfmt": {
				"run": "pnpm exec oxfmt --no-error-on-unmatched-pattern --write {staged_files}",
				"stage_fixed": true
			}
		}
	}
}
