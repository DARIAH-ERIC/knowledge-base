{
	"name": "@dariah-eric/email",
	"private": true,
	"license": "MIT",
	"files": [
		"./dist/"
	],
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": "./dist/index.mjs",
		"./errors": "./dist/errors.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@dariah-eric/configs": "workspace:^",
		"@types/node": "catalog:",
		"@types/nodemailer": "catalog:",
		"better-result": "catalog:",
		"eslint": "catalog:",
		"nodemailer": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"@types/nodemailer": "catalog:",
		"better-result": "catalog:",
		"nodemailer": "catalog:"
	},
	"engines": {
		"node": "24.x"
	}
}
