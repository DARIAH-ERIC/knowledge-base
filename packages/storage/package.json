{
	"name": "@dariah-eric/storage",
	"private": true,
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"imports": {
		"#/*": "./*"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./admin": "./dist/admin.mjs",
		"./errors": "./dist/errors.mjs",
		"./config": "./config/images.config.ts",
		"./lib": "./lib/utils/index.ts"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore",
		"format:fix": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"storage:buckets:create": "tsx ./scripts/create-buckets.ts",
		"storage:buckets:reset": "tsx ./scripts/reset-buckets.ts",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@dariah-eric/configs": "workspace:^",
		"@dariah-eric/env": "workspace:^",
		"@types/node": "catalog:",
		"better-result": "catalog:",
		"eslint": "catalog:",
		"minio": "catalog:",
		"prettier": "catalog:",
		"sharp": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"uuid": "catalog:",
		"valibot": "catalog:"
	},
	"peerDependencies": {
		"better-result": "catalog:",
		"minio": "catalog:",
		"uuid": "catalog:"
	},
	"engines": {
		"node": "24.x"
	}
}
