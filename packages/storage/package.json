{
	"name": "@dariah-eric/storage",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./config": "./config/images.config.ts",
		"./lib": "./lib/lib/index.ts"
	},
	"files": [
		"./dist/"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"storage:buckets:create": "tsx ./scripts/create-bucket.ts",
		"storage:buckets:reset": "tsx ./scripts/reset.ts",
		"storage:buckets:seed": "tsx ./scripts/seed.ts",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@dariah-eric/env": "workspace:^",
		"minio": "catalog:",
		"uuid": "catalog:",
		"valibot": "catalog:"
	},
	"devDependencies": {
		"@dariah-eric/configs": "workspace:^",
		"@faker-js/faker": "catalog:",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"sharp": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
