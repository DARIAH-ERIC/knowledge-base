{
	"name": "@dariah-eric/sshoc",
	"private": true,
	"license": "MIT",
	"type": "module",
	"exports": {
		".": "./dist/index.js"
	},
	"sideEffects": false,
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore",
		"format:fix": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write",
		"generate:api-client": "node ./scripts/generate-api-client.ts",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@dariah-eric/configs": "workspace:^",
		"@dariah-eric/request": "workspace:^",
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"openapi-typescript": "catalog:",
		"prettier": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@dariah-eric/request": "workspace:^"
	},
	"lint-staged": {
		"*.@(js|ts)": [
			"eslint --fix --flag unstable_native_nodejs_ts_config",
			"prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write"
		],
		"*.!(js|ts)": "prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --ignore-unknown --write"
	},
	"prettier": "@dariah-eric/configs/prettier"
}
