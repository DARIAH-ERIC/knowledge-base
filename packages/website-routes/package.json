{
	"name": "@dariah-eric/website-routes",
	"private": true,
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "oxlint --report-unused-disable-directives --type-aware --type-check",
		"lint:fix": "oxlint --fix --report-unused-disable-directives --type-aware --type-check",
		"test": "vitest run",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@dariah-eric/configs": "workspace:^",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:"
	},
	"engines": {
		"node": "24.x"
	}
}
