{
	"name": "@dariah-eric/env",
	"private": true,
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"engines": {
		"node": "24.x"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./errors": "./dist/errors.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@dariah-eric/configs": "workspace:^",
		"@types/node": "catalog:",
		"better-result": "catalog:",
		"eslint": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:",
		"valibot": "catalog:"
	},
	"peerDependencies": {
		"better-result": "catalog:",
		"valibot": "catalog:"
	}
}
