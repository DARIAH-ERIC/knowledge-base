{
	"name": "@dariah-eric/configs",
	"private": true,
	"license": "MIT",
	"type": "module",
	"sideEffects": false,
	"exports": {
		"./eslint/drizzle": "./lib/eslint/drizzle.ts",
		"./eslint/next": "./lib/eslint/next.ts",
		"./eslint/node": "./lib/eslint/node.ts",
		"./eslint/storybook": "./lib/eslint/storybook.ts",
		"./eslint/turbo": "./lib/eslint/turbo.ts",
		"./oxfmt/base": "./lib/oxfmt/base.ts",
		"./typescript/app": "./lib/typescript/app.json",
		"./typescript/app-build": "./lib/typescript/app-build.json",
		"./typescript/base": "./lib/typescript/lib.json",
		"./typescript/lib": "./lib/typescript/lib.json",
		"./typescript/lib-build": "./lib/typescript/lib-build.json"
	},
	"scripts": {
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@acdh-oeaw/eslint-config": "catalog:",
		"@acdh-oeaw/eslint-config-next": "catalog:",
		"@acdh-oeaw/eslint-config-node": "catalog:",
		"@acdh-oeaw/eslint-config-playwright": "catalog:",
		"@acdh-oeaw/eslint-config-react": "catalog:",
		"@acdh-oeaw/eslint-config-storybook": "catalog:",
		"@acdh-oeaw/eslint-config-tailwindcss": "catalog:",
		"@acdh-oeaw/tsconfig": "catalog:",
		"@acdh-oeaw/tsconfig-lib": "catalog:",
		"eslint-config-flat-gitignore": "catalog:",
		"eslint-config-turbo": "catalog:",
		"eslint-plugin-check-file": "catalog:",
		"eslint-plugin-drizzle": "catalog:",
		"eslint-plugin-perfectionist": "catalog:",
		"eslint-plugin-unicorn": "catalog:",
		"globals": "catalog:"
	},
	"devDependencies": {
		"@types/node": "catalog:",
		"eslint": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"eslint": "*",
		"typescript": "*"
	}
}
