{
	"name": "@dariah-eric/ui",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"exports": {
		"./avatar": "./dist/avatar.mjs",
		"./badge": "./dist/badge.mjs",
		"./breadcrumbs": "./dist/breadcrumbs.mjs",
		"./button": "./dist/button.mjs",
		"./calendar": "./dist/calendar.mjs",
		"./card": "./dist/card.mjs",
		"./carousel": "./dist/carousel.mjs",
		"./checkbox": "./dist/checkbox.mjs",
		"./command-menu": "./dist/command-menu.mjs",
		"./container": "./dist/container.mjs",
		"./date-field": "./dist/date-field.mjs",
		"./date-picker": "./dist/date-picker.mjs",
		"./description-list": "./dist/description-list.mjs",
		"./dialog": "./dist/dialog.mjs",
		"./field": "./dist/field.mjs",
		"./form": "./dist/form.mjs",
		"./form-error-message": "./dist/form-error-message.mjs",
		"./form-status": "./dist/form-status.mjs",
		"./form-success-message": "./dist/form-success-message.mjs",
		"./grid-list": "./dist/grid-list.mjs",
		"./heading": "./dist/heading.mjs",
		"./index": "./dist/index.mjs",
		"./input": "./dist/input.mjs",
		"./keyboard": "./dist/keyboard.mjs",
		"./link": "./dist/link.mjs",
		"./list-box": "./dist/list-box.mjs",
		"./loader": "./dist/loader.mjs",
		"./menu": "./dist/menu.mjs",
		"./meter": "./dist/meter.mjs",
		"./modal": "./dist/modal.mjs",
		"./multiple-select": "./dist/multiple-select.mjs",
		"./note": "./dist/note.mjs",
		"./pagination": "./dist/pagination.mjs",
		"./popover": "./dist/popover.mjs",
		"./progress-circle": "./dist/progress-circle.mjs",
		"./range-calendar": "./dist/range-calendar.mjs",
		"./rich-text-editor": "./dist/rich-text-editor.mjs",
		"./search-field": "./dist/search-field.mjs",
		"./select": "./dist/select.mjs",
		"./separator": "./dist/separator.mjs",
		"./sheet": "./dist/sheet.mjs",
		"./sidebar": "./dist/sidebar.mjs",
		"./submit-button": "./dist/submit-button.mjs",
		"./switch": "./dist/switch.mjs",
		"./table": "./dist/table.mjs",
		"./tabs": "./dist/tabs.mjs",
		"./tag-group": "./dist/tag-group.mjs",
		"./text": "./dist/text.mjs",
		"./textarea": "./dist/textarea.mjs",
		"./text-field": "./dist/text-field.mjs",
		"./time-field": "./dist/time-field.mjs",
		"./toast": "./dist/toast.mjs",
		"./toggle-group": "./dist/toggle-group.mjs",
		"./tooltip": "./dist/tooltip.mjs",
		"./tree": "./dist/tree.mjs",
		"./ui-provider": "./dist/ui-provider.mjs",
		"./i18n/en": "./dist/messages/en.json",
		"./styles": "./dist/styles/index.css"
	},
	"files": [
		"./dist/",
		"./messages/",
		"./styles/"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore",
		"format:fix": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:code:fix": "eslint . --flag unstable_native_nodejs_ts_config --fix",
		"lint:styles:check": "stylelint \"./styles/**/*.css\" --cache --ignore-path ./../../.gitignore",
		"lint:styles:fix": "stylelint \"./styles/**/*.css\" --cache --ignore-path ./../../.gitignore --fix",
		"storybook:build": "storybook build",
		"storybook:dev": "storybook dev --no-open --port 6006",
		"storybook:docs:build": "storybook build --docs",
		"storybook:docs:dev": "storybook dev --docs --no-open --port 6006",
		"test:unit": "vitest run --passWithNoTests --project=storybook",
		"test:watch": "vitest watch --passWithNoTests --project=storybook",
		"types:check": "tsc --noEmit"
	},
	"dependencies": {
		"@acdh-oeaw/lib": "catalog:",
		"@acdh-oeaw/style-variants": "catalog:",
		"@heroicons/react": "catalog:",
		"@internationalized/date": "catalog:",
		"@react-aria/utils": "catalog:",
		"@tiptap/core": "catalog:",
		"@tiptap/pm": "catalog:",
		"@tiptap/react": "catalog:",
		"@tiptap/starter-kit": "catalog:",
		"clsx": "catalog:",
		"embla-carousel-react": "catalog:",
		"lucide-react": "catalog:",
		"next-intl": "catalog:",
		"react": "catalog:",
		"react-aria": "catalog:",
		"react-aria-components": "catalog:",
		"react-dom": "catalog:",
		"recharts": "catalog:",
		"sonner": "catalog:",
		"tailwind-merge": "catalog:",
		"tailwind-variants": "catalog:"
	},
	"peerDependencies": {
		"@dariah-eric/next-lib": "workspace:^"
	},
	"devDependencies": {
		"@acdh-oeaw/stylelint-config": "catalog:",
		"@chromatic-com/storybook": "catalog:",
		"@dariah-eric/configs": "workspace:^",
		"@dariah-eric/next-lib": "workspace:^",
		"@fontsource-variable/fira-code": "catalog:",
		"@fontsource-variable/inter": "catalog:",
		"@storybook/addon-a11y": "catalog:",
		"@storybook/addon-docs": "catalog:",
		"@storybook/addon-themes": "catalog:",
		"@storybook/addon-vitest": "catalog:",
		"@storybook/react-vite": "catalog:",
		"@tailwindcss/vite": "catalog:",
		"@types/node": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"@vitejs/plugin-react": "catalog:",
		"@vitest/browser-playwright": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"eslint": "catalog:",
		"npm-run-all2": "catalog:",
		"playwright": "catalog:",
		"prettier": "catalog:",
		"storybook": "catalog:",
		"storybook-next-intl": "catalog:",
		"stylelint": "catalog:",
		"tailwindcss": "catalog:",
		"tailwindcss-react-aria-components": "catalog:",
		"tsdown": "catalog:",
		"tw-animate-css": "catalog:",
		"typescript": "catalog:",
		"vite": "catalog:",
		"vite-tsconfig-paths": "catalog:",
		"vitest": "catalog:"
	},
	"browserslist": {
		"development": [
			"baseline newly available"
		],
		"production": [
			"baseline widely available"
		]
	},
	"lint-staged": {
		"*.@(js|ts|tsx)": [
			"eslint --fix --flag unstable_native_nodejs_ts_config",
			"prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write"
		],
		"*.@(css)": [
			"stylelint --cache --fix",
			"prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write"
		],
		"*.!(css|js|ts|tsx)": "prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --ignore-unknown --write"
	},
	"postcss": {
		"plugins": {
			"@tailwindcss/postcss": {}
		}
	},
	"prettier": "@dariah-eric/configs/prettier",
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	}
}
