{
	"name": "@dariah-eric/request",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"sideEffects": false,
	"exports": {
		".": "./dist/index.mjs",
		"./errors": "./dist/errors.mjs"
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format:check": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore",
		"format:fix": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write",
		"lint:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"types:check": "tsc --noEmit"
	},
	"devDependencies": {
		"@dariah-eric/configs": "workspace:^",
		"@types/node": "catalog:",
		"better-result": "catalog:",
		"eslint": "catalog:",
		"is-network-error": "catalog:",
		"prettier": "catalog:",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"better-result": "catalog:",
		"is-network-error": "catalog:"
	}
}
