{
	"name": "@dariah-eric/knowledge-base",
	"private": true,
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"analyze": "next experimental-analyze",
		"build": "next build --experimental-next-config-strip-types",
		"dev": "PORT=3001 next dev --experimental-next-config-strip-types",
		"dev:watch": "PORT=3001 next dev --experimental-next-config-strip-types",
		"format:check": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore",
		"format:fix": "prettier . --cache --cache-location ./../../.prettiercache --check --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write",
		"i18n:convert-messages": "tsx ./scripts/i18n/convert-messages.ts",
		"i18n:extract-messages": "tsx ./scripts/i18n/extract-messages.ts",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:code:check": "eslint . --flag unstable_native_nodejs_ts_config",
		"lint:code:fix": "eslint . --fix --flag unstable_native_nodejs_ts_config",
		"lint:styles:check": "stylelint \"./styles/**/*.css\" --cache --ignore-path ./../../.gitignore",
		"lint:styles:fix": "stylelint \"./styles/**/*.css\" --cache --fix --ignore-path ./../../.gitignore",
		"prepare": "run-s types:prepare",
		"search:website:sync": "dotenvx run -q -f ./.env.local --ignore MISSING_ENV_FILE -- tsx ./scripts/search/sync-website-index.ts",
		"start": "PORT=3001 next start --experimental-next-config-strip-types",
		"test:e2e": "PORT=3001 playwright test --config ./e2e/playwright.config.ts",
		"test:e2e:codegen": "playwright codegen",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:ui": "pnpm run test:e2e --ui",
		"test:e2e:update-snapshots": "pnpm run test:e2e --update-snapshots",
		"types:check": "tsc --noEmit",
		"types:prepare": "ENV_VALIDATION=\"disabled\" next typegen"
	},
	"dependencies": {
		"@acdh-oeaw/color-schemes": "catalog:",
		"@acdh-oeaw/lib": "catalog:",
		"@acdh-oeaw/style-variants": "catalog:",
		"@dariah-eric/auth": "workspace:^",
		"@dariah-eric/client-campus": "workspace:^",
		"@dariah-eric/client-episciences": "workspace:^",
		"@dariah-eric/client-sshoc": "workspace:^",
		"@dariah-eric/client-zotero": "workspace:^",
		"@dariah-eric/database": "workspace:^",
		"@dariah-eric/email": "workspace:^",
		"@dariah-eric/env": "workspace:^",
		"@dariah-eric/images": "workspace:^",
		"@dariah-eric/mailchimp": "workspace:^",
		"@dariah-eric/next-lib": "workspace:^",
		"@dariah-eric/rate-limiter": "workspace:^",
		"@dariah-eric/request": "workspace:^",
		"@dariah-eric/search": "workspace:^",
		"@dariah-eric/storage": "workspace:^",
		"@dariah-eric/ui": "workspace:^",
		"@heroicons/react": "catalog:",
		"@internationalized/date": "catalog:",
		"@react-aria/utils": "catalog:",
		"@sentry/nextjs": "catalog:",
		"@sindresorhus/slugify": "catalog:",
		"@tiptap/core": "catalog:",
		"@tiptap/starter-kit": "catalog:",
		"@tiptap/static-renderer": "catalog:",
		"@valibot/i18n": "catalog:",
		"better-result": "catalog:",
		"client-only": "catalog:",
		"clsx": "catalog:",
		"is-network-error": "catalog:",
		"lucide-react": "catalog:",
		"motion": "catalog:",
		"next": "catalog:",
		"next-intl": "catalog:",
		"nodemailer": "catalog:",
		"react": "catalog:",
		"react-aria": "catalog:",
		"react-aria-components": "catalog:",
		"react-dom": "catalog:",
		"react-schemaorg": "catalog:",
		"server-nodejs-only": "catalog:",
		"server-only": "catalog:",
		"sharp": "catalog:",
		"sonner": "catalog:",
		"tailwind-merge": "catalog:",
		"tailwind-variants": "catalog:",
		"uqr": "catalog:",
		"use-debounce": "catalog:",
		"uuid": "catalog:",
		"valibot": "catalog:",
		"xast-util-feed": "catalog:",
		"xast-util-to-xml": "catalog:"
	},
	"devDependencies": {
		"@acdh-oeaw/stylelint-config": "catalog:",
		"@dariah-eric/configs": "workspace:^",
		"@dotenvx/dotenvx": "catalog:",
		"@next/eslint-plugin-next": "catalog:",
		"@playwright/test": "catalog:",
		"@react-aria/optimize-locales-plugin": "catalog:",
		"@tailwindcss/postcss": "catalog:",
		"@types/node": "catalog:",
		"@types/nodemailer": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"axe-core": "catalog:",
		"axe-playwright": "catalog:",
		"babel-plugin-react-compiler": "catalog:",
		"concurrently": "catalog:",
		"eslint": "catalog:",
		"is-in-ci": "catalog:",
		"next-devtools-mcp": "catalog:",
		"npm-run-all2": "catalog:",
		"null-loader": "catalog:",
		"po-parser": "catalog:",
		"prettier": "catalog:",
		"schema-dts": "catalog:",
		"stylelint": "catalog:",
		"tailwindcss": "catalog:",
		"tailwindcss-react-aria-components": "catalog:",
		"tsx": "catalog:",
		"tw-animate-css": "catalog:",
		"typescript": "catalog:"
	},
	"browserslist": {
		"development": [
			"baseline newly available"
		],
		"production": [
			"baseline widely available"
		]
	},
	"lint-staged": {
		"*.@(js|ts|tsx)": [
			"eslint --fix --flag unstable_native_nodejs_ts_config",
			"prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write"
		],
		"*.@(css)": [
			"stylelint --cache --fix",
			"prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --write"
		],
		"*.!(css|js|ts|tsx)": "prettier --cache --cache-location ./../../.prettiercache --ignore-path ./../../.gitignore --ignore-path ./../../.prettierignore --ignore-unknown --write"
	},
	"postcss": {
		"plugins": {
			"@tailwindcss/postcss": {}
		}
	},
	"prettier": "@dariah-eric/configs/prettier",
	"stylelint": {
		"extends": "@acdh-oeaw/stylelint-config"
	}
}
