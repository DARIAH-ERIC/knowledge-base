# =================================================================================================
# environment variables for next.js application
# =================================================================================================

# =================================================================================================
# app
# =================================================================================================

# local
# -------------------------------------------------------------------------------------------------

NEXT_PUBLIC_WEBSITE_BASE_URL="http://localhost:3002"
# imprint service
NEXT_PUBLIC_WEBSITE_IMPRINT_CUSTOM_CONFIG="enabled"
NEXT_PUBLIC_WEBSITE_IMPRINT_SERVICE_BASE_URL="https://imprint.acdh.oeaw.ac.at"
NEXT_PUBLIC_WEBSITE_SERVICE_ID="25534"
# web crawlers
NEXT_PUBLIC_WEBSITE_BOTS="disabled"
# validate environment variables
ENV_VALIDATION="enabled"

# =================================================================================================
# analytics
# =================================================================================================

# production
# -------------------------------------------------------------------------------------------------

# NEXT_PUBLIC_WEBSITE_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_WEBSITE_MATOMO_BASE_URL="https://matomo.acdh.oeaw.ac.at"
