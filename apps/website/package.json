{
	"name": "@dariah-eric/website",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"analyze": "next experimental-analyze",
		"build": "next build --experimental-next-config-strip-types",
		"dev": "PORT=3002 next dev --experimental-next-config-strip-types",
		"dev:watch": "PORT=3002 next dev --experimental-next-config-strip-types",
		"format:check": "oxfmt --check",
		"format:fix": "oxfmt --write",
		"lint:check": "run-p --continue-on-error \"lint:*:check\"",
		"lint:code:check": "oxlint --report-unused-disable-directives --type-aware --type-check",
		"lint:code:fix": "oxlint --fix --report-unused-disable-directives --type-aware --type-check --quiet",
		"lint:fix": "run-p --continue-on-error \"lint:*:fix\"",
		"lint:styles:check": "stylelint \"./styles/**/*.css\" --cache --config-basedir ../../packages/config --ignore-path ./../../.gitignore",
		"lint:styles:fix": "stylelint \"./styles/**/*.css\" --cache --fix --ignore-path ./../../.gitignore",
		"prepare": "run-s types:prepare",
		"start": "PORT=3002 next start --experimental-next-config-strip-types",
		"test:e2e": "PORT=3002 playwright test --config ./e2e/playwright.config.ts",
		"test:e2e:codegen": "playwright codegen",
		"test:e2e:install": "playwright install --with-deps",
		"test:e2e:ui": "pnpm run test:e2e --ui",
		"test:e2e:update-snapshots": "pnpm run test:e2e --update-snapshots",
		"types:check": "tsc --noEmit",
		"types:prepare": "ENV_VALIDATION=\"disabled\" next typegen"
	},
	"dependencies": {
		"@acdh-oeaw/color-schemes": "catalog:",
		"@acdh-oeaw/lib": "catalog:",
		"@acdh-oeaw/style-variants": "catalog:",
		"@dariah-eric/database": "workspace:^",
		"@dariah-eric/email": "workspace:^",
		"@dariah-eric/env": "workspace:^",
		"@dariah-eric/images": "workspace:^",
		"@dariah-eric/mailchimp": "workspace:^",
		"@dariah-eric/next-lib": "workspace:^",
		"@dariah-eric/rate-limiter": "workspace:^",
		"@dariah-eric/request": "workspace:^",
		"@dariah-eric/search": "workspace:^",
		"@dariah-eric/ui": "workspace:^",
		"@react-aria/utils": "catalog:",
		"@sentry/nextjs": "catalog:",
		"@valibot/i18n": "catalog:",
		"client-only": "catalog:",
		"clsx": "catalog:",
		"is-network-error": "catalog:",
		"lucide-react": "catalog:",
		"next": "catalog:",
		"next-intl": "catalog:",
		"nodemailer": "catalog:",
		"react": "catalog:",
		"react-aria": "catalog:",
		"react-aria-components": "catalog:",
		"react-dom": "catalog:",
		"react-schemaorg": "catalog:",
		"server-nodejs-only": "catalog:",
		"server-only": "catalog:",
		"sharp": "catalog:",
		"uuid": "catalog:",
		"valibot": "catalog:",
		"xast-util-feed": "catalog:",
		"xast-util-to-xml": "catalog:"
	},
	"devDependencies": {
		"@dariah-eric/configs": "workspace:^",
		"@dotenvx/dotenvx": "catalog:",
		"@playwright/test": "catalog:",
		"@react-aria/optimize-locales-plugin": "catalog:",
		"@tailwindcss/postcss": "catalog:",
		"@types/node": "catalog:",
		"@types/nodemailer": "catalog:",
		"@types/react": "catalog:",
		"@types/react-dom": "catalog:",
		"axe-core": "catalog:",
		"axe-playwright": "catalog:",
		"babel-plugin-react-compiler": "catalog:",
		"concurrently": "catalog:",
		"is-in-ci": "catalog:",
		"next-devtools-mcp": "catalog:",
		"npm-run-all2": "catalog:",
		"null-loader": "catalog:",
		"schema-dts": "catalog:",
		"stylelint": "catalog:",
		"tailwindcss": "catalog:",
		"tailwindcss-react-aria-components": "catalog:",
		"tsx": "catalog:",
		"tw-animate-css": "catalog:",
		"typescript": "catalog:"
	},
	"stylelint": {
		"extends": "@dariah-eric/configs/stylelint/base"
	},
	"engines": {
		"node": "24.x"
	},
	"postcss": {
		"plugins": {
			"@tailwindcss/postcss": {}
		}
	}
}
