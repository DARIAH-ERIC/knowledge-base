# TYPESENSE_ADMIN_API_KEY=
# TYPESENSE_HOST="typesense.acdh-dev.oeaw.ac.at"
# TYPESENSE_PORT="443"
# TYPESENSE_PROTOCOL="https"
# TYPESENSE_SEARCH_API_KEY=

# =================================================================================================
# observability
# =================================================================================================

# traces are exported to an opentelemetry collector when an endpoint is set; leaving it unset (the
# default) disables tracing, e.g. in local development and ci. the `/health` endpoint is never
# traced. (sentry is used for error reporting only, not tracing.)
#
# in deployments `OTEL_EXPORTER_OTLP_ENDPOINT` is provided as a github organization variable in the
# acdh-oeaw org, but that defaults to the otlp/grpc endpoint (port 4317). we export via otlp http,
# so the endpoint must be overridden to the http port: "http://k8s-infra-otel-agent.signoz-k8s-infra:4318".

# production
# -------------------------------------------------------------------------------------------------

# OTEL_EXPORTER_OTLP_ENDPOINT="http://k8s-infra-otel-agent.signoz-k8s-infra:4318"
# OTEL_EXPORTER_OTLP_HEADERS="authorization=Bearer <token>"
