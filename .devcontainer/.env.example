# =================================================================================================
# environment variables for local development containers
# =================================================================================================

# =================================================================================================
# auth
# =================================================================================================

AUTH_ENCRYPTION_KEY=# `openssl rand --hex 16`
AUTH_SIGN_UP="disabled"

# =================================================================================================
# database
# =================================================================================================

DATABASE_HOST="localhost" # replace with "postgres" service name in devcontainer
DATABASE_NAME="dariah-knowledge-base"
DATABASE_PASSWORD=# `openssl rand --hex 32`
DATABASE_PORT="5432"
# DATABASE_SSL_CONNECTION="disabled"
DATABASE_USER="dariah-knowledge-base"

# =================================================================================================
# search
# =================================================================================================

NEXT_PUBLIC_TYPESENSE_RESOURCE_COLLECTION_NAME="dariah-resources"
NEXT_PUBLIC_TYPESENSE_WEBSITE_COLLECTION_NAME="dariah-website"

NEXT_PUBLIC_TYPESENSE_HOST="localhost"
NEXT_PUBLIC_TYPESENSE_PORT="8108"
NEXT_PUBLIC_TYPESENSE_PROTOCOL="http"
# NEXT_PUBLIC_TYPESENSE_SEARCH_API_KEY=
TYPESENSE_ADMIN_API_KEY=# `openssl rand --hex 32`

TYPESENSE_DASHBOARD_PORT="5050"

# =================================================================================================
# email
# =================================================================================================

EMAIL_ADDRESS="acdh@example.com"
EMAIL_SMTP_PORT="1025"
EMAIL_SMTP_SERVER="localhost"
# EMAIL_SSL_CONNECTION="disabled"

MAILPIT_API_BASE_URL="http://localhost:8025"
MAILPIT_API_PORT="8025"

# =================================================================================================
# storage
# =================================================================================================

S3_BUCKET_NAME="dariah-knowledge-base"

# also used for minio web ui sign-in
S3_ACCESS_KEY=# `openssl rand --hex 16`
S3_HOST="localhost"
S3_PORT="9000"
S3_PROTOCOL="http"
# also used for minio web ui sign-in
S3_SECRET_KEY=# `openssl rand --hex 32`

MINIO_WEB_UI_PORT="9001"

# =================================================================================================
# images
# =================================================================================================

IMGPROXY_BASE_URL="http://localhost:8080"
IMGPROXY_KEY=# `openssl rand --hex 32`
IMGPROXY_PORT="8080"
IMGPROXY_SALT=# `openssl rand --hex 16`
